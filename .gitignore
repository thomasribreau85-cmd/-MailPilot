# ============================================================
# .gitignore — Fichiers à ne PAS mettre sur Git
# ============================================================

# Secrets et configuration locale
.env
credentials.json
token.json

# Environnement virtuel Python
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Distribution Python
*.egg-info/
dist/
build/
